PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
USE_MONGOOSE=false
USE_MEMORY_DB=false
MONGODB_URI=mongodb://127.0.0.1:27017/dhub
JWT_ACCESS_SECRET=dhub-dev-access-secret-change-me
JWT_REFRESH_SECRET=dhub-dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
BOOTSTRAP_ADMIN_EMAIL=admin@dhub.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_NAME=DHub Administrator
UPLOAD_MAX_BYTES=10485760
SMTP_ENABLED=false
