PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
# Render production example:
# CLIENT_ORIGIN=https://huedora-projects.onrender.com

# Data store: file DB by default (JSON under server/data). For MongoDB set:
# USE_MONGOOSE=true
# MONGODB_URI=mongodb://127.0.0.1:27017/tylo-one
USE_MONGOOSE=false
USE_MEMORY_DB=false
MONGODB_URI=mongodb://127.0.0.1:27017/tylo-one

# REQUIRED in production (32+ random characters each — no placeholders)
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Optional first-run only: create the initial Admin user if none exists.
# Leave blank after first admin is created. Password min 12 characters.
# BOOTSTRAP_ADMIN_EMAIL=you@company.com
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=Administrator
# One-shot password recovery for that bootstrap email (set true, redeploy, then false):
# BOOTSTRAP_ADMIN_RESET=false

UPLOAD_MAX_BYTES=10485760
SMTP_ENABLED=false

# Dev-only sample data (ignored when NODE_ENV=production)
SEED_AGREEMENT_SAMPLES=false
SEED_DEMO_USERS=false

# One-shot production wipe: commit server/.fresh-start, deploy, then remove the file.
# Or set RESET_ALL_DATA_ON_BOOT=true for one deploy, then turn it off.
# RESET_ALL_DATA_ON_BOOT=false
# No separate Camp One secrets are required. API is mounted at /api/v1/camp-ops.
# Optional future email connector stubs (unused until SMTP/IMAP is wired):
# CAMP_OPS_EMAIL_ENABLED=false
# CAMP_OPS_EMAIL_HOST=
# CAMP_OPS_EMAIL_PORT=993
# CAMP_OPS_EMAIL_USER=
# CAMP_OPS_EMAIL_PASSWORD=
# CAMP_OPS_EMAIL_MAILBOX=INBOX
